Project senhong_ocop {
  database_type: 'MySQL'
  Note: 'SENHONG OCOP SYSTEM - Conceptual Data Model (CDM)'
}

// ========================================
// 1. USER MANAGEMENT ENTITIES
// ========================================

Table users {
  id bigint(20) unsigned [pk]
  name varchar(255) [not null]
  email varchar(255) [unique, not null]
  email_verified_at timestamp [nullable]
  password varchar(255) [not null]
  phone varchar(20) [unique, nullable]
  avatar varchar(255) [nullable]
  role enum('admin', 'staff', 'customer', 'supplier') [default: 'customer']
  is_active tinyint(1) [default: 1]
  lock_expires_at timestamp [nullable]
  lock_enabled_by bigint(20) unsigned [nullable]
  remember_token varchar(100) [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']
  
  indexes {
    idx_email (email)
    idx_role (role)
    idx_is_active (is_active)
  }
}

Table staffs {
  user_id bigint(20) unsigned [pk]
  phone varchar(20) [nullable]
  date_of_birth date [nullable]
  address text [nullable]
  position enum('manager', 'staff', 'leader', 'director') [default: 'staff']
  start_date date [nullable]
  probation_start date [nullable]
  probation_end date [nullable]
  employment_status enum('probation', 'official', 'resigned') [default: 'probation']
  probation_hourly_wage decimal(10,2) [nullable]
  official_hourly_wage decimal(10,2) [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_position (position)
    idx_employment_status (employment_status)
  }
}

Ref: staffs.user_id > users.id [delete: cascade]

Table customers {
  id bigint(20) unsigned [pk]
  user_id bigint(20) unsigned [unique, nullable]
  phone varchar(20) [nullable]
  date_of_birth date [nullable]
  address text [nullable]
  is_default_address tinyint(1) [default: 0]
  province_code varchar(5) [nullable]
  district_code varchar(5) [nullable]
  ward_code varchar(5) [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_province (province_code)
    idx_created_at (created_at)
  }
}

Ref: customers.user_id > users.id [delete: cascade]

// ========================================
// 2. ATTENDANCE & HR MANAGEMENT
// ========================================

Table attendances {
  id bigint(20) unsigned [pk]
  staff_id bigint(20) unsigned [not null]
  work_date date [not null]
  shift enum('morning', 'afternoon') [not null]
  expected_check_in time [not null]
  expected_check_out time [not null]
  check_in time [nullable]
  check_in_ip varchar(45) [nullable]
  check_in_latitude decimal(10,7) [nullable]
  check_in_longitude decimal(10,7) [nullable]
  check_in_network_type varchar(50) [nullable]
  check_in_distance_meters decimal(8,2) [nullable]
  check_in_verification_method varchar(20) [nullable]
  check_out time [nullable]
  check_out_ip varchar(45) [nullable]
  check_out_latitude decimal(10,7) [nullable]
  check_out_longitude decimal(10,7) [nullable]
  check_out_network_type varchar(50) [nullable]
  check_out_distance_meters decimal(8,2) [nullable]
  check_out_verification_method varchar(20) [nullable]
  is_late tinyint(1) [default: 0]
  is_early_leave tinyint(1) [default: 0]
  is_completed tinyint(1) [default: 0]
  is_auto_checkout_forced tinyint(1) [default: 0]
  early_leave_reason text [nullable]
  early_leave_status enum('pending', 'approved', 'rejected') [default: 'pending']
  early_leave_pay_percent int [default: 100]
  early_leave_approved_by bigint(20) unsigned [nullable]
  early_leave_approved_at timestamp [nullable]
  scenario_type tinyint(3) unsigned [nullable]
  worked_minutes int [nullable]
  salary_amount decimal(12,2) [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    uk_staff_date_shift (staff_id, work_date, shift) [unique]
    idx_work_date (work_date)
    idx_is_complete (is_completed)
    idx_scenario_type (scenario_type)
  }
}

Ref: attendances.staff_id > staffs.user_id [delete: cascade]
Ref: attendances.early_leave_approved_by > staffs.user_id [delete: set null]

Table salaries {
  id bigint(20) unsigned [pk]
  staff_id bigint(20) unsigned [not null]
  month int(2) [nullable]
  year int(4) [nullable]
  total_hours decimal(8,2) [nullable]
  total_amount decimal(12,2) [nullable]
  bonus decimal(12,2) [default: 0]
  penalty decimal(12,2) [default: 0]
  absent_count int [default: 0]
  absent_amount decimal(12,2) [default: 0]
  final_amount decimal(12,2) [nullable]
  status enum('draft', 'approved', 'paid') [default: 'draft']
  notes text [nullable]
  paid_at timestamp [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    uk_staff_month_year (staff_id, month, year) [unique]
    idx_status (status)
  }
}

Ref: salaries.staff_id > staffs.user_id [delete: cascade]

// ========================================
// 3. SUPPLY CHAIN & INVENTORY
// ========================================

Table suppliers {
  id bigint(20) unsigned [pk]
  name varchar(255) [not null]
  email varchar(255) [nullable]
  phone varchar(20) [nullable]
  address text [nullable]
  city varchar(100) [nullable]
  province_code varchar(5) [nullable]
  tax_code varchar(20) [nullable]
  contact_person varchar(255) [nullable]
  is_active tinyint(1) [default: 1]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_name (name)
    idx_is_active (is_active)
  }
}

Table category_products {
  id bigint(20) unsigned [pk]
  name varchar(255) [unique, not null]
  description text [nullable]
  image_url varchar(255) [nullable]
  slug varchar(255) [unique, nullable]
  display_order int [default: 0]
  is_active tinyint(1) [default: 1]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_name (name)
    idx_display_order (display_order)
  }
}

Table products {
  id bigint(20) unsigned [pk]
  category_id bigint(20) unsigned [not null]
  name varchar(255) [not null]
  type enum('simple', 'bundle', 'variable') [default: 'simple']
  description longtext [nullable]
  origin varchar(100) [nullable]
  is_active tinyint(1) [default: 1]
  is_featured tinyint(1) [default: 0]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_category_id (category_id)
    idx_is_active (is_active)
    idx_is_featured (is_featured)
  }
}

Ref: products.category_id > category_products.id [delete: restrict]

Table product_variants {
  id bigint(20) unsigned [pk]
  product_id bigint(20) unsigned [not null]
  sku varchar(50) [unique, not null]
  name varchar(255) [nullable]
  size varchar(50) [nullable]
  color varchar(50) [nullable]
  weight decimal(8,2) [nullable]
  unit varchar(20) [nullable]
  cost_price decimal(12,2) [nullable]
  selling_price decimal(12,2) [not null]
  display_price decimal(12,2) [nullable]
  thickness int [nullable]
  is_active tinyint(1) [default: 1]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_product_id (product_id)
    idx_sku (sku)
    idx_is_active (is_active)
  }
}

Ref: product_variants.product_id > products.id [delete: cascade]

Table product_images {
  id bigint(20) unsigned [pk]
  product_id bigint(20) unsigned [not null]
  product_variant_id bigint(20) unsigned [nullable]
  path varchar(255) [not null]
  is_primary tinyint(1) [default: 0]
  display_order int [default: 0]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']

  indexes {
    idx_product_id (product_id)
    idx_is_primary (is_primary)
  }
}

Ref: product_images.product_id > products.id [delete: cascade]
Ref: product_images.product_variant_id > product_variants.id [delete: set null]

Table imports {
  id bigint(20) unsigned [pk]
  supplier_id bigint(20) unsigned [not null]
  staff_id bigint(20) unsigned [not null]
  import_date date [not null]
  notes text [nullable]
  status enum('draft', 'imported', 'cancelled') [default: 'draft']
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_import_date (import_date)
    idx_status (status)
  }
}

Ref: imports.supplier_id > suppliers.id [delete: restrict]
Ref: imports.staff_id > staffs.user_id [delete: restrict]

Table import_items {
  id bigint(20) unsigned [pk]
  import_id bigint(20) unsigned [not null]
  product_variant_id bigint(20) unsigned [not null]
  quantity int [not null]
  remaining_quantity int [not null, default: 0]
  cost_price decimal(12,2) [nullable]
  manufacturing_date date [nullable]
  expiry_date date [nullable]
  batch_number varchar(100) [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_import_id (import_id)
    idx_expiry_date (expiry_date)
  }
}

Ref: import_items.import_id > imports.id [delete: cascade]
Ref: import_items.product_variant_id > product_variants.id [delete: restrict]

Table inventories {
  id bigint(20) unsigned [pk]
  product_variant_id bigint(20) unsigned [unique, not null]
  total_quantity int [default: 0]
  available_quantity int [default: 0]
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_available_qty (available_quantity)
  }
}

Ref: inventories.product_variant_id > product_variants.id [delete: cascade]

Table inventory_writeoffs {
  id bigint(20) unsigned [pk]
  product_variant_id bigint(20) unsigned [not null]
  import_item_id bigint(20) unsigned [nullable]
  quantity int [not null]
  reason enum('expired', 'damaged', 'lost', 'other') [default: 'damaged']
  notes text [nullable]
  writeoff_date date [default: 'CURRENT_DATE']
  approved_by bigint(20) unsigned [nullable]
  approved_at timestamp [nullable]
  status enum('pending', 'approved', 'rejected') [default: 'pending']
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_status (status)
    idx_writeoff_date (writeoff_date)
  }
}

Ref: inventory_writeoffs.product_variant_id > product_variants.id [delete: restrict]
Ref: inventory_writeoffs.import_item_id > import_items.id [delete: set null]
Ref: inventory_writeoffs.approved_by > staffs.user_id [delete: set null]

// ========================================
// 4. E-COMMERCE: ORDERS & PAYMENTS
// ========================================

Table orders {
  id bigint(20) unsigned [pk]
  order_number varchar(50) [unique, not null]
  customer_id bigint(20) unsigned [nullable]
  total_amount decimal(12,2) [not null]
  shipping_fee decimal(12,2) [default: 0]
  discount decimal(12,2) [default: 0]
  final_amount decimal(12,2) [not null]
  status enum('pending', 'processing', 'shipped', 'delivered', 'cancelled', 'refunded', 'completed') [default: 'pending']
  previous_status varchar(50) [nullable]
  shipping_method varchar(100) [nullable]
  shipping_address text [nullable]
  shipping_city varchar(100) [nullable]
  shipping_province_code varchar(5) [nullable]
  shipping_name varchar(255) [nullable]
  shipping_phone varchar(20) [nullable]
  notes text [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_order_number (order_number)
    idx_status (status)
    idx_created_at (created_at)
    idx_customer_id (customer_id)
    idx_orders_customer_date (customer_id, created_at)
  }
}

Ref: orders.customer_id > customers.id [delete: set null]

Table order_items {
  id bigint(20) unsigned [pk]
  order_id bigint(20) unsigned [not null]
  product_variant_id bigint(20) unsigned [not null]
  quantity int [not null]
  unit_price decimal(12,2) [nullable]
  display_price decimal(12,2) [nullable]
  total_price decimal(12,2) [nullable]
  batch_number varchar(100) [nullable]
  manufacturing_date date [nullable]
  expiry_date date [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']

  indexes {
    idx_order_id (order_id)
    idx_order_items_order_variant (order_id, product_variant_id)
  }
}

Ref: order_items.order_id > orders.id [delete: cascade]
Ref: order_items.product_variant_id > product_variants.id [delete: restrict]

Table order_cancellations {
  id bigint(20) unsigned [pk]
  order_id bigint(20) unsigned [unique, not null]
  reason varchar(255) [nullable]
  cancelled_by varchar(50) [nullable]
  cancelled_at timestamp [default: 'CURRENT_TIMESTAMP']

  indexes {
    idx_cancelled_at (cancelled_at)
  }
}

Ref: order_cancellations.order_id > orders.id [delete: cascade]

Table payments {
  id bigint(20) unsigned [pk]
  order_id bigint(20) unsigned [not null]
  amount decimal(12,2) [not null]
  payment_method enum('cash', 'bank_transfer', 'credit_card', 'e_wallet', 'other') [default: 'cash']
  payment_gateway varchar(100) [nullable]
  transaction_id varchar(255) [unique, nullable]
  status enum('pending', 'completed', 'failed', 'refunded', 'cancelled') [default: 'pending']
  refund_amount decimal(12,2) [nullable]
  refund_reason text [nullable]
  refunded_at timestamp [nullable]
  notes text [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_order_id (order_id)
    idx_status (status)
  }
}

Ref: payments.order_id > orders.id [delete: cascade]

Table order_returns {
  id bigint(20) unsigned [pk]
  order_id bigint(20) unsigned [not null]
  reason varchar(255) [nullable]
  description text [nullable]
  status enum('pending', 'approved', 'rejected', 'returned', 'refunded') [default: 'pending']
  refund_amount decimal(12,2) [nullable]
  requested_at timestamp [default: 'CURRENT_TIMESTAMP']
  approved_at timestamp [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_status (status)
  }
}

Ref: order_returns.order_id > orders.id [delete: cascade]

Table order_return_images {
  id bigint(20) unsigned [pk]
  order_return_id bigint(20) unsigned [not null]
  image_path varchar(255) [nullable]
  uploaded_at timestamp [default: 'CURRENT_TIMESTAMP']

  indexes {
    idx_return_id (order_return_id)
  }
}

Ref: order_return_images.order_return_id > order_returns.id [delete: cascade]

Table wishlists {
  id bigint(20) unsigned [pk]
  customer_id bigint(20) unsigned [not null]
  product_variant_id bigint(20) unsigned [not null]
  added_at timestamp [default: 'CURRENT_TIMESTAMP']

  indexes {
    uk_customer_variant (customer_id, product_variant_id) [unique]
    idx_customer_id (customer_id)
  }
}

Ref: wishlists.customer_id > customers.id [delete: cascade]
Ref: wishlists.product_variant_id > product_variants.id [delete: cascade]

// ========================================
// 5. PROMOTIONS & DISCOUNTS
// ========================================

Table discounts {
  id bigint(20) unsigned [pk]
  code varchar(50) [unique, not null]
  description text [nullable]
  discount_type enum('percentage', 'fixed_amount') [default: 'percentage']
  discount_value decimal(12,2) [not null]
  max_discount_amount decimal(12,2) [nullable]
  min_order_amount decimal(12,2) [nullable]
  usage_limit int [nullable]
  usage_count int [default: 0]
  start_date date [nullable]
  end_date date [nullable]
  audience enum('all', 'new_customers', 'loyal_customers', 'specific') [default: 'all']
  is_active tinyint(1) [default: 1]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_code (code)
    idx_is_active (is_active)
    idx_start_date (start_date)
    idx_end_date (end_date)
  }
}

Table discount_usages {
  id bigint(20) unsigned [pk]
  discount_id bigint(20) unsigned [not null]
  order_id bigint(20) unsigned [nullable]
  customer_id bigint(20) unsigned [nullable]
  used_at timestamp [default: 'CURRENT_TIMESTAMP']

  indexes {
    idx_discount_id (discount_id)
  }
}

Ref: discount_usages.discount_id > discounts.id [delete: cascade]
Ref: discount_usages.order_id > orders.id [delete: set null]
Ref: discount_usages.customer_id > customers.id [delete: set null]

Table discount_product {
  discount_id bigint(20) unsigned [pk]
  product_id bigint(20) unsigned [pk]
}

Ref: discount_product.discount_id > discounts.id [delete: cascade]
Ref: discount_product.product_id > products.id [delete: cascade]

// ========================================
// 6. CONTENT MANAGEMENT & REVIEWS
// ========================================

Table blogs {
  id bigint(20) unsigned [pk]
  title varchar(255) [not null]
  slug varchar(255) [unique, not null]
  summary text [nullable]
  content longtext [nullable]
  image varchar(255) [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_slug (slug)
    idx_created_at (created_at)
  }
}

Table blog_blocks {
  id bigint(20) unsigned [pk]
  blog_id bigint(20) unsigned [not null]
  type enum('text', 'image') [default: 'text']
  content text [nullable]
  image varchar(255) [nullable]
  position int [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_blog_id (blog_id)
  }
}

Ref: blog_blocks.blog_id > blogs.id [delete: cascade]

Table reviews {
  id bigint(20) unsigned [pk]
  customer_id bigint(20) unsigned [nullable]
  product_id bigint(20) unsigned [not null]
  order_item_id bigint(20) unsigned [nullable]
  rating int [not null]
  title varchar(255) [nullable]
  comment text [nullable]
  anonymous tinyint(1) [default: 0]
  status enum('pending', 'approved', 'rejected') [default: 'pending']
  helpful_count int [default: 0]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_product_id (product_id)
    idx_status (status)
    idx_rating (rating)
  }
}

Ref: reviews.customer_id > customers.id [delete: set null]
Ref: reviews.product_id > products.id [delete: cascade]
Ref: reviews.order_item_id > order_items.id [delete: set null]

Table review_likes {
  id bigint(20) unsigned [pk]
  review_id bigint(20) unsigned [not null]
  customer_id bigint(20) unsigned [nullable]
  liked_at timestamp [default: 'CURRENT_TIMESTAMP']

  indexes {
    uk_review_customer_like (review_id, customer_id) [unique]
    idx_review_id (review_id)
  }
}

Ref: review_likes.review_id > reviews.id [delete: cascade]
Ref: review_likes.customer_id > customers.id [delete: set null]

Table review_replies {
  id bigint(20) unsigned [pk]
  review_id bigint(20) unsigned [not null]
  staff_id bigint(20) unsigned [nullable]
  comment text [not null]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_review_id (review_id)
  }
}

Ref: review_replies.review_id > reviews.id [delete: cascade]
Ref: review_replies.staff_id > staffs.user_id [delete: set null]

Table contacts {
  id bigint(20) unsigned [pk]
  name varchar(255) [nullable]
  email varchar(255) [nullable]
  message text [nullable]
  status enum('pending', 'read') [default: 'pending']
  reply text [nullable]
  replied_at timestamp [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_status (status)
    idx_created_at (created_at)
  }
}

Table customer_messages {
  id bigint(20) unsigned [pk]
  customer_id bigint(20) unsigned [not null]
  product_id bigint(20) unsigned [nullable]
  staff_id bigint(20) unsigned [nullable]
  message text [not null]
  is_read tinyint(1) [default: 0]
  read_at timestamp [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']
  updated_at timestamp [default: 'CURRENT_TIMESTAMP ON UPDATE']

  indexes {
    idx_customer_id (customer_id)
    idx_is_read (is_read)
    idx_created_at (created_at)
  }
}

Ref: customer_messages.customer_id > customers.id [delete: cascade]
Ref: customer_messages.product_id > products.id [delete: set null]
Ref: customer_messages.staff_id > staffs.user_id [delete: set null]

Table notifications {
  id bigint(20) unsigned [pk]
  user_id bigint(20) unsigned [not null]
  type varchar(100) [nullable]
  message text [nullable]
  read_at timestamp [nullable]
  created_at timestamp [default: 'CURRENT_TIMESTAMP']

  indexes {
    idx_user_id (user_id)
    idx_read_at (read_at)
  }
}

Ref: notifications.user_id > users.id [delete: cascade]
