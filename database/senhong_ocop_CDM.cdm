  <Entity Name="reviews" Code="reviews" DefinitionPrm="0">
    <Description>Product reviews and ratings</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
