      </Attribute>
      <Attribute Name="order_number" Code="order_number" DataType="varchar(50)" Mandatory="1" SearchKey="1">
        <Description>Order number (unique)</Description>
      </Attribute>
      <Attribute Name="customer_id" Code="customer_id" DataType="bigint(20)" Mandatory="0" SearchKey="1">
        <Description>Foreign key to customers (optional for guest orders)</Description>
      </Attribute>
      <Attribute Name="total_amount" Code="total_amount" DataType="decimal(12,2)" Mandatory="1">
        <Description>Total amount before discount/shipping</Description>
      </Attribute>
      <Attribute Name="shipping_fee" Code="shipping_fee" DataType="decimal(12,2)" Mandatory="1" Default="0">
        <Description>Shipping fee</Description>
      </Attribute>
