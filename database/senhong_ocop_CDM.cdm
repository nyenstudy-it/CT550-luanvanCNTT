        <Description>Final amount (total + shipping - discount)</Description>
      </Attribute>
      <Attribute Name="status" Code="status" DataType="enum('pending','processing','shipped','delivered','cancelled','refunded','completed')" Mandatory="1" Default="pending">
        <Description>Order status</Description>
      </Attribute>
      <Attribute Name="previous_status" Code="previous_status" DataType="varchar(50)" Mandatory="0">
        <Description>Previous order status</Description>
      </Attribute>
      <Attribute Name="shipping_method" Code="shipping_method" DataType="varchar(100)" Mandatory="0">
