        <Description>Discount start date</Description>
      </Attribute>
      <Attribute Name="end_date" Code="end_date" DataType="date" Mandatory="0">
        <Description>Discount end date</Description>
      </Attribute>
      <Attribute Name="audience" Code="audience" DataType="enum('all','new_customers','loyal_customers','specific')" Mandatory="1" Default="all">
        <Description>Target audience</Description>
      </Attribute>
      <Attribute Name="is_active" Code="is_active" DataType="tinyint(1)" Mandatory="1" Default="1">
        <Description>Is discount active?</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
      </Attribute>
