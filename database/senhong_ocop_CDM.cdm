<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Model SYSTEM "CDM.dtd">
<Model Name="senhong_ocop" Code="senhong_ocop" TargetModel="WebSphere" Version="16.1.2.4" SyntaxVersion="16.1-0">
  <Description>SENHONG OCOP SYSTEM - Conceptual Data Model (CDM)
Database: senhong_ocop (MySQL)
Created: April 16, 2026
Purpose: Complete ERD for OCOP Shop Management System
Modules: User Mgmt, Attendance &amp; HR, Supply Chain, E-Commerce, Promotions, Content Management</Description>
  <DiagramLayout ScaleFactor="100" XMargin="50" YMargin="50" />

  <!-- ================================================== -->
  <!-- 1. USER MANAGEMENT ENTITIES -->
  <!-- ================================================== -->
  
  <Entity Name="users" Code="users" DefinitionPrm="0">
    <Description>System users (admin, staff, customer, supplier)</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Primary key - Unique user identifier</Description>
      </Attribute>
      <Attribute Name="name" Code="name" DataType="varchar(255)" Mandatory="1">
        <Description>User full name</Description>
      </Attribute>
      <Attribute Name="email" Code="email" DataType="varchar(255)" Mandatory="1" Searchable="1">
        <Description>User email address (unique)</Description>
      </Attribute>
      <Attribute Name="email_verified_at" Code="email_verified_at" DataType="timestamp" Mandatory="0">
        <Description>Email verification timestamp</Description>
      </Attribute>
      <Attribute Name="password" Code="password" DataType="varchar(255)" Mandatory="1">
        <Description>Hashed password</Description>
      </Attribute>
      <Attribute Name="phone" Code="phone" DataType="varchar(20)" Mandatory="0" Searchable="1">
        <Description>Phone number (unique)</Description>
      </Attribute>
      <Attribute Name="avatar" Code="avatar" DataType="varchar(255)" Mandatory="0">
        <Description>Avatar image URL</Description>
      </Attribute>
      <Attribute Name="role" Code="role" DataType="enum('admin','staff','customer','supplier')" Mandatory="1">
        <Description>User role (enum)</Description>
      </Attribute>
      <Attribute Name="is_active" Code="is_active" DataType="tinyint(1)" Mandatory="1" Default="1">
        <Description>Active status (1=active, 0=inactive)</Description>
      </Attribute>
      <Attribute Name="lock_expires_at" Code="lock_expires_at" DataType="timestamp" Mandatory="0">
        <Description>Account lock expiration timestamp</Description>
      </Attribute>
      <Attribute Name="lock_enabled_by" Code="lock_enabled_by" DataType="bigint(20)" Mandatory="0">
        <Description>User ID who locked this account</Description>
      </Attribute>
      <Attribute Name="remember_token" Code="remember_token" DataType="varchar(100)" Mandatory="0">
        <Description>Remember me token</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
      </Attribute>
    </Attributes>
    <Identifier Name="pk_users" Code="pk_users">
      <IdentifierAttribute Name="id" />
    </Identifier>
    <UniqueKey Name="uk_email" Code="uk_email">
      <UniqueKeyAttribute Name="email" />
    </UniqueKey>
    <UniqueKey Name="uk_phone" Code="uk_phone">
      <UniqueKeyAttribute Name="phone" />
    </UniqueKey>
  </Entity>

  <Entity Name="staffs" Code="staffs" DefinitionPrm="0">
    <Description>Staff profile information (employees)</Description>
    <Attributes>
      <Attribute Name="user_id" Code="user_id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Foreign key to users table</Description>
      </Attribute>
      <Attribute Name="phone" Code="phone" DataType="varchar(20)" Mandatory="0">
        <Description>Staff phone number</Description>
      </Attribute>
      <Attribute Name="date_of_birth" Code="date_of_birth" DataType="date" Mandatory="0">
        <Description>Date of birth</Description>
      </Attribute>
      <Attribute Name="address" Code="address" DataType="text" Mandatory="0">
        <Description>Residential address</Description>
      </Attribute>
      <Attribute Name="position" Code="position" DataType="enum('manager','staff','leader','director')" Mandatory="1" Default="staff">
        <Description>Position/role in organization</Description>
      </Attribute>
      <Attribute Name="start_date" Code="start_date" DataType="date" Mandatory="0">
        <Description>Employment start date</Description>
      </Attribute>
      <Attribute Name="probation_start" Code="probation_start" DataType="date" Mandatory="0">
        <Description>Probation period start date</Description>
      </Attribute>
      <Attribute Name="probation_end" Code="probation_end" DataType="date" Mandatory="0">
        <Description>Probation period end date</Description>
      </Attribute>
      <Attribute Name="employment_status" Code="employment_status" DataType="enum('probation','official','resigned')" Mandatory="1" Default="probation">
        <Description>Employment status</Description>
      </Attribute>
      <Attribute Name="probation_hourly_wage" Code="probation_hourly_wage" DataType="decimal(10,2)" Mandatory="0">
        <Description>Hourly wage during probation</Description>
      </Attribute>
      <Attribute Name="official_hourly_wage" Code="official_hourly_wage" DataType="decimal(10,2)" Mandatory="0">
        <Description>Hourly wage after probation</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
      </Attribute>
    </Attributes>
    <Identifier Name="pk_staffs" Code="pk_staffs">
      <IdentifierAttribute Name="user_id" />
    </Identifier>
  </Entity>

  <Entity Name="customers" Code="customers" DefinitionPrm="0">
    <Description>Customer profile information</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Primary key - Unique customer identifier</Description>
      </Attribute>
      <Attribute Name="user_id" Code="user_id" DataType="bigint(20)" Mandatory="0" SearchKey="1">
        <Description>Foreign key to users table (optional)</Description>
      </Attribute>
      <Attribute Name="phone" Code="phone" DataType="varchar(20)" Mandatory="0">
        <Description>Customer phone number</Description>
      </Attribute>
      <Attribute Name="date_of_birth" Code="date_of_birth" DataType="date" Mandatory="0">
        <Description>Date of birth</Description>
      </Attribute>
      <Attribute Name="address" Code="address" DataType="text" Mandatory="0">
        <Description>Residential address</Description>
      </Attribute>
      <Attribute Name="is_default_address" Code="is_default_address" DataType="tinyint(1)" Mandatory="1" Default="0">
        <Description>Is this the default address?</Description>
      </Attribute>
      <Attribute Name="province_code" Code="province_code" DataType="varchar(5)" Mandatory="0">
        <Description>Province code (location hierarchy)</Description>
      </Attribute>
      <Attribute Name="district_code" Code="district_code" DataType="varchar(5)" Mandatory="0">
        <Description>District code (location hierarchy)</Description>
      </Attribute>
      <Attribute Name="ward_code" Code="ward_code" DataType="varchar(5)" Mandatory="0">
        <Description>Ward code (location hierarchy)</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
      </Attribute>
    </Attributes>
    <Identifier Name="pk_customers" Code="pk_customers">
      <IdentifierAttribute Name="id" />
    </Identifier>
    <UniqueKey Name="uk_user_id" Code="uk_user_id">
      <UniqueKeyAttribute Name="user_id" />
    </UniqueKey>
  </Entity>

  <!-- ================================================== -->
  <!-- 2. ATTENDANCE &amp; HR MANAGEMENT -->
  <!-- ================================================== -->

  <Entity Name="attendances" Code="attendances" DefinitionPrm="0">
    <Description>Daily attendance tracking with 5 scenarios (late, early leave, etc.)</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Primary key - Unique attendance record</Description>
      </Attribute>
      <Attribute Name="staff_id" Code="staff_id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Foreign key to staffs table</Description>
      </Attribute>
      <Attribute Name="work_date" Code="work_date" DataType="date" Mandatory="1" SearchKey="1">
        <Description>Work date</Description>
      </Attribute>
      <Attribute Name="shift" Code="shift" DataType="enum('morning','afternoon')" Mandatory="1" SearchKey="1">
        <Description>Work shift (morning/afternoon)</Description>
      </Attribute>
      <Attribute Name="expected_check_in" Code="expected_check_in" DataType="time" Mandatory="1">
        <Description>Expected check-in time</Description>
      </Attribute>
      <Attribute Name="expected_check_out" Code="expected_check_out" DataType="time" Mandatory="1">
        <Description>Expected check-out time</Description>
      </Attribute>
      <Attribute Name="check_in" Code="check_in" DataType="time" Mandatory="0">
        <Description>Actual check-in time</Description>
      </Attribute>
      <Attribute Name="check_in_ip" Code="check_in_ip" DataType="varchar(45)" Mandatory="0">
        <Description>IP address at check-in</Description>
      </Attribute>
      <Attribute Name="check_in_latitude" Code="check_in_latitude" DataType="decimal(10,7)" Mandatory="0">
        <Description>GPS latitude at check-in</Description>
      </Attribute>
      <Attribute Name="check_in_longitude" Code="check_in_longitude" DataType="decimal(10,7)" Mandatory="0">
        <Description>GPS longitude at check-in</Description>
      </Attribute>
      <Attribute Name="check_in_network_type" Code="check_in_network_type" DataType="varchar(50)" Mandatory="0">
        <Description>Network type at check-in (WiFi/Mobile/etc)</Description>
      </Attribute>
      <Attribute Name="check_in_distance_meters" Code="check_in_distance_meters" DataType="decimal(8,2)" Mandatory="0">
        <Description>Distance from office in meters at check-in</Description>
      </Attribute>
      <Attribute Name="check_in_verification_method" Code="check_in_verification_method" DataType="varchar(20)" Mandatory="0">
        <Description>Verification method used for check-in</Description>
      </Attribute>
      <Attribute Name="check_out" Code="check_out" DataType="time" Mandatory="0">
        <Description>Actual check-out time</Description>
      </Attribute>
      <Attribute Name="check_out_ip" Code="check_out_ip" DataType="varchar(45)" Mandatory="0">
        <Description>IP address at check-out</Description>
      </Attribute>
      <Attribute Name="check_out_latitude" Code="check_out_latitude" DataType="decimal(10,7)" Mandatory="0">
        <Description>GPS latitude at check-out</Description>
      </Attribute>
      <Attribute Name="check_out_longitude" Code="check_out_longitude" DataType="decimal(10,7)" Mandatory="0">
        <Description>GPS longitude at check-out</Description>
      </Attribute>
      <Attribute Name="check_out_network_type" Code="check_out_network_type" DataType="varchar(50)" Mandatory="0">
        <Description>Network type at check-out</Description>
      </Attribute>
      <Attribute Name="check_out_distance_meters" Code="check_out_distance_meters" DataType="decimal(8,2)" Mandatory="0">
        <Description>Distance from office in meters at check-out</Description>
      </Attribute>
      <Attribute Name="check_out_verification_method" Code="check_out_verification_method" DataType="varchar(20)" Mandatory="0">
        <Description>Verification method used for check-out</Description>
      </Attribute>
      <Attribute Name="is_late" Code="is_late" DataType="tinyint(1)" Mandatory="1" Default="0">
        <Description>Is staff late? (Scenario 1)</Description>
      </Attribute>
      <Attribute Name="is_early_leave" Code="is_early_leave" DataType="tinyint(1)" Mandatory="1" Default="0">
        <Description>Did staff leave early? (Scenario 2)</Description>
      </Attribute>
      <Attribute Name="is_completed" Code="is_completed" DataType="tinyint(1)" Mandatory="1" Default="0">
        <Description>Is attendance record completed?</Description>
      </Attribute>
      <Attribute Name="is_auto_checkout_forced" Code="is_auto_checkout_forced" DataType="tinyint(1)" Mandatory="1" Default="0">
        <Description>Was auto check-out forced? (Scenario 5)</Description>
      </Attribute>
      <Attribute Name="early_leave_reason" Code="early_leave_reason" DataType="text" Mandatory="0">
        <Description>Reason for early leave</Description>
      </Attribute>
      <Attribute Name="early_leave_status" Code="early_leave_status" DataType="enum('pending','approved','rejected')" Mandatory="1" Default="pending">
        <Description>Status of early leave request</Description>
      </Attribute>
      <Attribute Name="early_leave_pay_percent" Code="early_leave_pay_percent" DataType="int" Mandatory="1" Default="100">
        <Description>Pay percentage for early leave (0-100)</Description>
      </Attribute>
      <Attribute Name="early_leave_approved_by" Code="early_leave_approved_by" DataType="bigint(20)" Mandatory="0">
        <Description>Staff ID who approved early leave</Description>
      </Attribute>
      <Attribute Name="early_leave_approved_at" Code="early_leave_approved_at" DataType="timestamp" Mandatory="0">
        <Description>Timestamp when early leave was approved</Description>
      </Attribute>
      <Attribute Name="scenario_type" Code="scenario_type" DataType="tinyint(3)" Mandatory="0">
        <Description>Attendance scenario type (1-5)</Description>
      </Attribute>
      <Attribute Name="worked_minutes" Code="worked_minutes" DataType="int" Mandatory="0">
        <Description>Total minutes worked</Description>
      </Attribute>
      <Attribute Name="salary_amount" Code="salary_amount" DataType="decimal(12,2)" Mandatory="0">
        <Description>Salary amount for this attendance record</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
      </Attribute>
    </Attributes>
    <Identifier Name="pk_attendances" Code="pk_attendances">
      <IdentifierAttribute Name="id" />
    </Identifier>
    <UniqueKey Name="uk_staff_date_shift" Code="uk_staff_date_shift">
      <UniqueKeyAttribute Name="staff_id" />
      <UniqueKeyAttribute Name="work_date" />
      <UniqueKeyAttribute Name="shift" />
    </UniqueKey>
  </Entity>

  <Entity Name="salaries" Code="salaries" DefinitionPrm="0">
    <Description>Monthly salary calculation with bonuses and penalties</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Primary key - Unique salary record</Description>
      </Attribute>
      <Attribute Name="staff_id" Code="staff_id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Foreign key to staffs table</Description>
      </Attribute>
      <Attribute Name="month" Code="month" DataType="int(2)" Mandatory="0">
        <Description>Month (1-12)</Description>
      </Attribute>
      <Attribute Name="year" Code="year" DataType="int(4)" Mandatory="0">
        <Description>Year (YYYY)</Description>
      </Attribute>
      <Attribute Name="total_hours" Code="total_hours" DataType="decimal(8,2)" Mandatory="0">
        <Description>Total hours worked in month</Description>
      </Attribute>
      <Attribute Name="total_amount" Code="total_amount" DataType="decimal(12,2)" Mandatory="0">
        <Description>Total salary before bonus/penalty</Description>
      </Attribute>
      <Attribute Name="bonus" Code="bonus" DataType="decimal(12,2)" Mandatory="1" Default="0">
        <Description>Bonus amount</Description>
      </Attribute>
      <Attribute Name="penalty" Code="penalty" DataType="decimal(12,2)" Mandatory="1" Default="0">
        <Description>Penalty amount</Description>
      </Attribute>
      <Attribute Name="absent_count" Code="absent_count" DataType="int" Mandatory="1" Default="0">
        <Description>Number of absent days</Description>
      </Attribute>
      <Attribute Name="absent_amount" Code="absent_amount" DataType="decimal(12,2)" Mandatory="1" Default="0">
        <Description>Amount deducted for absences</Description>
      </Attribute>
      <Attribute Name="final_amount" Code="final_amount" DataType="decimal(12,2)" Mandatory="0">
        <Description>Final salary (total + bonus - penalty - absent_amount)</Description>
      </Attribute>
      <Attribute Name="status" Code="status" DataType="enum('draft','approved','paid')" Mandatory="1" Default="draft">
        <Description>Salary status</Description>
      </Attribute>
      <Attribute Name="notes" Code="notes" DataType="text" Mandatory="0">
        <Description>Additional notes about salary</Description>
      </Attribute>
      <Attribute Name="paid_at" Code="paid_at" DataType="timestamp" Mandatory="0">
        <Description>Timestamp when salary was paid</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
      </Attribute>
    </Attributes>
    <Identifier Name="pk_salaries" Code="pk_salaries">
      <IdentifierAttribute Name="id" />
    </Identifier>
    <UniqueKey Name="uk_staff_month_year" Code="uk_staff_month_year">
      <UniqueKeyAttribute Name="staff_id" />
      <UniqueKeyAttribute Name="month" />
      <UniqueKeyAttribute Name="year" />
    </UniqueKey>
  </Entity>

  <!-- ================================================== -->
  <!-- 3. SUPPLIER &amp; INVENTORY -->
  <!-- ================================================== -->

  <Entity Name="suppliers" Code="suppliers" DefinitionPrm="0">
    <Description>Supplier information</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Primary key - Unique supplier identifier</Description>
      </Attribute>
      <Attribute Name="name" Code="name" DataType="varchar(255)" Mandatory="1" Searchable="1">
        <Description>Supplier name</Description>
      </Attribute>
      <Attribute Name="email" Code="email" DataType="varchar(255)" Mandatory="0">
        <Description>Supplier email</Description>
      </Attribute>
      <Attribute Name="phone" Code="phone" DataType="varchar(20)" Mandatory="0">
        <Description>Supplier phone</Description>
      </Attribute>
      <Attribute Name="address" Code="address" DataType="text" Mandatory="0">
        <Description>Supplier address</Description>
      </Attribute>
      <Attribute Name="city" Code="city" DataType="varchar(100)" Mandatory="0">
        <Description>City</Description>
      </Attribute>
      <Attribute Name="province_code" Code="province_code" DataType="varchar(5)" Mandatory="0">
        <Description>Province code</Description>
      </Attribute>
      <Attribute Name="tax_code" Code="tax_code" DataType="varchar(20)" Mandatory="0">
        <Description>Tax identification code</Description>
      </Attribute>
      <Attribute Name="contact_person" Code="contact_person" DataType="varchar(255)" Mandatory="0">
        <Description>Contact person name</Description>
      </Attribute>
      <Attribute Name="is_active" Code="is_active" DataType="tinyint(1)" Mandatory="1" Default="1">
        <Description>Is supplier active?</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
      </Attribute>
    </Attributes>
    <Identifier Name="pk_suppliers" Code="pk_suppliers">
      <IdentifierAttribute Name="id" />
    </Identifier>
  </Entity>

  <Entity Name="category_products" Code="category_products" DefinitionPrm="0">
    <Description>Product categories</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Primary key - Unique category identifier</Description>
      </Attribute>
      <Attribute Name="name" Code="name" DataType="varchar(255)" Mandatory="1" Searchable="1">
        <Description>Category name (unique)</Description>
      </Attribute>
      <Attribute Name="description" Code="description" DataType="text" Mandatory="0">
        <Description>Category description</Description>
      </Attribute>
      <Attribute Name="image_url" Code="image_url" DataType="varchar(255)" Mandatory="0">
        <Description>Category image URL</Description>
      </Attribute>
      <Attribute Name="slug" Code="slug" DataType="varchar(255)" Mandatory="0">
        <Description>URL slug (unique)</Description>
      </Attribute>
      <Attribute Name="display_order" Code="display_order" DataType="int" Mandatory="1" Default="0">
        <Description>Display order in UI</Description>
      </Attribute>
      <Attribute Name="is_active" Code="is_active" DataType="tinyint(1)" Mandatory="1" Default="1">
        <Description>Is category active?</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
      </Attribute>
    </Attributes>
    <Identifier Name="pk_category_products" Code="pk_category_products">
      <IdentifierAttribute Name="id" />
    </Identifier>
    <UniqueKey Name="uk_category_name" Code="uk_category_name">
      <UniqueKeyAttribute Name="name" />
    </UniqueKey>
    <UniqueKey Name="uk_category_slug" Code="uk_category_slug">
      <UniqueKeyAttribute Name="slug" />
    </UniqueKey>
  </Entity>

  <Entity Name="products" Code="products" DefinitionPrm="0">
    <Description>Product master data</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Primary key - Unique product identifier</Description>
      </Attribute>
      <Attribute Name="category_id" Code="category_id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Foreign key to category_products</Description>
      </Attribute>
      <Attribute Name="name" Code="name" DataType="varchar(255)" Mandatory="1" Searchable="1">
        <Description>Product name</Description>
      </Attribute>
      <Attribute Name="type" Code="type" DataType="enum('simple','bundle','variable')" Mandatory="1" Default="simple">
        <Description>Product type</Description>
      </Attribute>
      <Attribute Name="description" Code="description" DataType="longtext" Mandatory="0">
        <Description>Product description</Description>
      </Attribute>
      <Attribute Name="origin" Code="origin" DataType="varchar(100)" Mandatory="0">
        <Description>Product origin/source</Description>
      </Attribute>
      <Attribute Name="is_active" Code="is_active" DataType="tinyint(1)" Mandatory="1" Default="1">
        <Description>Is product active?</Description>
      </Attribute>
      <Attribute Name="is_featured" Code="is_featured" DataType="tinyint(1)" Mandatory="1" Default="0">
        <Description>Is product featured?</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
      </Attribute>
    </Attributes>
    <Identifier Name="pk_products" Code="pk_products">
      <IdentifierAttribute Name="id" />
    </Identifier>
  </Entity>

  <Entity Name="product_variants" Code="product_variants" DefinitionPrm="0">
    <Description>Product variants (size, color, volume, etc.)</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Primary key - Unique variant identifier</Description>
      </Attribute>
      <Attribute Name="product_id" Code="product_id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Foreign key to products</Description>
      </Attribute>
      <Attribute Name="sku" Code="sku" DataType="varchar(50)" Mandatory="1" SearchKey="1">
        <Description>Stock keeping unit (unique)</Description>
      </Attribute>
      <Attribute Name="name" Code="name" DataType="varchar(255)" Mandatory="0">
        <Description>Variant name</Description>
      </Attribute>
      <Attribute Name="size" Code="size" DataType="varchar(50)" Mandatory="0">
        <Description>Size attribute</Description>
      </Attribute>
      <Attribute Name="color" Code="color" DataType="varchar(50)" Mandatory="0">
        <Description>Color attribute</Description>
      </Attribute>
      <Attribute Name="weight" Code="weight" DataType="decimal(8,2)" Mandatory="0">
        <Description>Weight in kg</Description>
      </Attribute>
      <Attribute Name="unit" Code="unit" DataType="varchar(20)" Mandatory="0">
        <Description>Unit of measurement</Description>
      </Attribute>
      <Attribute Name="cost_price" Code="cost_price" DataType="decimal(12,2)" Mandatory="0">
