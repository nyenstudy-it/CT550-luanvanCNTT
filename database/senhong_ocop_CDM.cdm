  <!-- ================================================== -->
  <!-- 5. PROMOTIONS &amp; DISCOUNTS -->
  <!-- ================================================== -->

  <Entity Name="discounts" Code="discounts" DefinitionPrm="0">
    <Description>Discount/promotion codes</Description>
    <Attributes>
      <Attribute Name="id" Code="id" DataType="bigint(20)" Mandatory="1" SearchKey="1">
        <Description>Primary key - Unique discount record</Description>
      </Attribute>
      <Attribute Name="code" Code="code" DataType="varchar(50)" Mandatory="1" SearchKey="1">
        <Description>Discount code (unique)</Description>
      </Attribute>
      <Attribute Name="description" Code="description" DataType="text" Mandatory="0">
        <Description>Discount description</Description>
      </Attribute>
      <Attribute Name="discount_type" Code="discount_type" DataType="enum('percentage','fixed_amount')" Mandatory="1" Default="percentage">
        <Description>Discount type</Description>
      </Attribute>
      <Attribute Name="discount_value" Code="discount_value" DataType="decimal(12,2)" Mandatory="1">
        <Description>Discount value (% or amount)</Description>
      </Attribute>
      <Attribute Name="max_discount_amount" Code="max_discount_amount" DataType="decimal(12,2)" Mandatory="0">
        <Description>Maximum discount amount capping</Description>
      </Attribute>
      <Attribute Name="min_order_amount" Code="min_order_amount" DataType="decimal(12,2)" Mandatory="0">
        <Description>Minimum order amount to apply discount</Description>
      </Attribute>
      <Attribute Name="usage_limit" Code="usage_limit" DataType="int" Mandatory="0">
        <Description>Total usage limit</Description>
      </Attribute>
      <Attribute Name="usage_count" Code="usage_count" DataType="int" Mandatory="1" Default="0">
        <Description>Current usage count</Description>
      </Attribute>
