      </Attribute>
      <Attribute Name="shipping_address" Code="shipping_address" DataType="text" Mandatory="0">
        <Description>Shipping address</Description>
      </Attribute>
      <Attribute Name="shipping_city" Code="shipping_city" DataType="varchar(100)" Mandatory="0">
        <Description>Shipping city</Description>
      </Attribute>
      <Attribute Name="shipping_province_code" Code="shipping_province_code" DataType="varchar(5)" Mandatory="0">
        <Description>Shipping province code</Description>
      </Attribute>
      <Attribute Name="shipping_name" Code="shipping_name" DataType="varchar(255)" Mandatory="0">
        <Description>Recipient name</Description>
      </Attribute>
      <Attribute Name="shipping_phone" Code="shipping_phone" DataType="varchar(20)" Mandatory="0">
        <Description>Recipient phone</Description>
      </Attribute>
      <Attribute Name="notes" Code="notes" DataType="text" Mandatory="0">
        <Description>Order notes</Description>
      </Attribute>
      <Attribute Name="created_at" Code="created_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP">
        <Description>Record creation timestamp</Description>
      </Attribute>
      <Attribute Name="updated_at" Code="updated_at" DataType="timestamp" Mandatory="1" Default="CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
        <Description>Record last update timestamp</Description>
